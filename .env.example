# =============================================================================
# OCPP Management - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# Django Core
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# CSRF trusted origins (include https:// prefix)
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Set to False if SSL is terminated at nginx (recommended)
SECURE_SSL_REDIRECT=False

# Database (set DB_ENGINE=postgresql for production)
DB_ENGINE=postgresql
DB_NAME=ocpp_management
DB_USER=ocpp_user
DB_PASSWORD=strong-password-here
DB_HOST=localhost
DB_PORT=5432

# Redis (required for production WebSocket support)
REDIS_URL=redis://localhost:6379/0

# OCPP Settings
OCPP_ACCEPT_UNKNOWN_CHARGERS=False
